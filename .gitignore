# =============================================================================
# Futures Trading Co-Pilot — .gitignore
# =============================================================================

# --- Python ---
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
*.whl
.eggs/
*.mypy_cache/

# --- Virtual environments ---
.venv/
venv/
ENV/

# --- Environment & secrets ---
.env
.env.*
!.env.example

# --- IDE / Editor ---
.idea/
.vscode/
*.swp
*.swo
*~
.project
.settings/

# --- OS junk ---
.DS_Store
Thumbs.db
desktop.ini

# --- Data & databases ---
*.db
*.sqlite
*.sqlite3
/data/
archive/

# --- Logs ---
*.log
logs/

# --- Test / coverage artifacts ---
.coverage
htmlcov/
.pytest_cache/
.ruff_cache/

# --- Claude / AI ---
.claude/

# --- Docker volumes (local) ---
postgres_data/
redis_data/
grafana_data/
prometheus_data/

# --- Analysis output ---
codebase_summary.md

# =============================================================================
# CNN Models — generated by the trainer service (lib.services.training.trainer_server)
# =============================================================================
# Epoch checkpoints (timestamped) and archive are not committed — they are
# large and only useful locally.  The champion files and metadata ARE committed
# so the Windows deploy script can pull them directly from this repo.
models/*
!models/.gitkeep

# ── Champion model files (committed) ─────────────────────────────────────────
# These are the files consumed by the engine (PT) and exported as ONNX.
# Updated by the trainer after each successful promotion run.
!models/breakout_cnn_best.pt
!models/breakout_cnn_best.onnx
!models/breakout_cnn_best_meta.json
!models/feature_contract.json

# ── Archive subdirectory (not committed) ─────────────────────────────────────
models/archive/

*.png
